# =============================================================================
# JJA DEV LAB - Configuration Production (OVH)
# Copier ce fichier en .env.prod.local et remplir les valeurs
# =============================================================================

APP_ENV=prod
APP_SECRET=CHANGER_AVEC_UNE_CLE_ALEATOIRE_DE_32_CHARS

# --- Base de données OVH ---
DB_USER=votre_user_mysql
DB_PASSWORD=votre_mot_de_passe
DB_HOST=votre_host_mysql.mysql.db
DB_PORT=3306
DB_NAME=votre_base
DB_VERSION=mariadb-10.6.0

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=votre_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre_client_secret

# --- Push Notifications (VAPID) ---
VAPID_PUBLIC_KEY=votre_cle_publique_vapid
VAPID_PRIVATE_KEY=votre_cle_privee_vapid

# --- Gemini AI ---
GEMINI_API_KEY=votre_cle_gemini

# --- Cloudflare Turnstile (Captcha) ---
TURNSTILE_KEY=votre_cle_site
TURNSTILE_SECRET=votre_cle_secrete

# --- Mailer OVH ---
MAILER_DSN=smtp://user:pass@ssl0.ovh.net:465

# --- Sécurité Admin ---
ADMIN_ALLOWED_IPS=127.0.0.1,::1,VOTRE_IP_FIXE
