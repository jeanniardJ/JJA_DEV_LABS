{
  "scanSettings": {
    "baseBranches": ["master", "develop"],
    "ignoreSourceFiles": true,
    "ignoreNpmDirs": true,
    "scanPackageManagerDirectives": true
  },
  "checkRunSettings": {
    "vulnerableCheckRunConclusionLevel": "failure",
    "displayMode": "diff",
    "useMendCheckNames": true
  },
  "issueSettings": {
    "minSeverityLevel": "MEDIUM",
    "issueType": "DEPENDENCY"
  },
  "remediateSettings": {
    "extends": "config:base",
    "workflow": "pullRequest",
    "ignoredDependencies": []
  }
}
