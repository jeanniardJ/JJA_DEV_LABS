{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard | JJA DEV LAB{% endblock %}

{% block body %}
<div class="max-w-full mx-auto py-8">
    <div class="flex items-center justify-between mb-8 px-4">
        <div>
            <h1 class="text-2xl font-bold text-white font-mono uppercase tracking-[0.2em]">COMMAND_CENTER</h1>
            <p class="text-xs text-lab-muted font-mono mt-1">// PIPELINE_DE_LEADS_ACTIF</p>
        </div>
        <div class="flex items-center gap-4">
            <!-- Sort Controls -->
            <div class="flex items-center gap-2 mr-4 text-[10px] font-mono text-lab-muted">
                <span class="uppercase">Trier par:</span>
                <a href="{{ path('admin_dashboard', {sort: 'createdAt', direction: current_direction == 'DESC' ? 'ASC' : 'DESC'}) }}" 
                   class="hover:text-white {{ current_sort == 'createdAt' ? 'text-lab-primary font-bold' : '' }}">
                   Date
                   {% if current_sort == 'createdAt' %}
                       <i data-lucide="{{ current_direction == 'DESC' ? 'arrow-down' : 'arrow-up' }}" class="w-3 h-3 inline"></i>
                   {% endif %}
                </a>
                <span class="text-lab-border">|</span>
                <a href="{{ path('admin_dashboard', {sort: 'name', direction: current_direction == 'DESC' ? 'ASC' : 'DESC'}) }}" 
                   class="hover:text-white {{ current_sort == 'name' ? 'text-lab-primary font-bold' : '' }}">
                   Nom
                   {% if current_sort == 'name' %}
                       <i data-lucide="{{ current_direction == 'DESC' ? 'arrow-down' : 'arrow-up' }}" class="w-3 h-3 inline"></i>
                   {% endif %}
                </a>
            </div>

            <div class="text-right hidden md:block">
                <p class="text-[9px] text-lab-muted font-mono uppercase">Session: {{ app.user.userIdentifier }}</p>
                <p class="text-[9px] text-lab-terminal font-mono uppercase">Level: Admin_Privileges</p>
            </div>
            <a href="{{ path('admin_logout') }}" class="p-2 border border-lab-border hover:border-lab-danger text-lab-muted hover:text-lab-danger transition-colors">
                <i data-lucide="log-out" class="w-4 h-4"></i>
            </a>
        </div>
    </div>

    <!-- Kanban Board -->
    <div class="flex gap-4 overflow-x-auto pb-8 px-4 min-h-[70vh]" 
         data-controller="kanban"
         data-kanban-update-url-value="{{ path('api_admin_lead_update_status', {id: 'ID_PLACEHOLDER'}) }}">
        
        {% for status in statuses %}
            <div class="flex-shrink-0 w-72 flex flex-col bg-lab-panel/30 border border-lab-border/50 rounded-sm">
                <!-- Column Header -->
                <div class="p-3 border-b border-lab-border/50 flex items-center justify-between bg-black/20">
                    <div class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 rounded-full bg-lab-primary"></div>
                        <h2 class="text-[10px] font-mono font-bold text-white uppercase tracking-widest">{{ status.getLabel() }}</h2>
                    </div>
                    <span class="text-[10px] font-mono text-lab-muted bg-lab-bg px-1.5 py-0.5 border border-lab-border/30 rounded-sm">
                        {{ grouped_leads[status.value]|length }}
                    </span>
                </div>

                <!-- Column Body (Draggable) -->
                <div class="flex-1 p-2 space-y-3 overflow-y-auto" 
                     data-kanban-target="column" 
                     data-status="{{ status.value }}">
                    
                    {% for lead in grouped_leads[status.value] %}
                        {{ include('admin/leads/_card.html.twig', {lead: lead}) }}
                    {% endfor %}
                </div>
            </div>
        {% endfor %}
    </div>
</div>

<!-- Side Panel Detail (Turbo Frame placeholder) -->
<div id="lead-detail-panel" class="fixed inset-y-0 right-0 z-50 flex transform translate-x-full transition-transform duration-300 ease-in-out">
    <!-- Overlay/Backdrop Area (Transparent but clickable to close) -->
    <div class="w-screen h-full absolute inset-0 -left-full bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300"
         id="lead-detail-overlay"
         data-action="click->kanban#hideDetails"></div>

    <!-- Panel -->
    <div class="w-full max-w-lg bg-lab-panel border-l border-lab-border shadow-2xl relative z-10 h-full">
        <turbo-frame id="lead_detail">
            <!-- Content will be loaded here -->
        </turbo-frame>
    </div>
</div>
{% endblock %}
