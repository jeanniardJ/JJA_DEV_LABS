{% extends 'admin/layout.html.twig' %}

{% block title %}JJA DEV LAB | ADMIN MAINFRAME{% endblock %}

{% block admin_breadcrumb %}Vue d'ensemble{% endblock %}

{% block admin_body %}
<div data-controller="kanban" 
     data-kanban-update-url-value="{{ path('api_admin_lead_update_status', {id: 'ID_PLACEHOLDER'}) }}"
     class="space-y-8">
    
    <!-- SECTION TITRE -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-3xl font-black text-white uppercase tracking-tighter leading-none">Mainframe Kernel</h1>
            <p class="text-lab-muted font-mono text-xs mt-2 uppercase tracking-widest">Séquence de monitoring temps réel initialisée</p>
        </div>
        <div class="flex gap-2">
            <a href="{{ path('admin_export_report') }}" class="px-4 py-2 bg-lab-primary/10 border border-lab-primary/40 text-lab-primary font-mono text-[10px] uppercase hover:bg-lab-primary hover:text-black transition-all">
                Exporter Rapport
            </a>
            <form method="post" action="{{ path('admin_panic_mode') }}" 
                  data-controller="confirmation" 
                  data-confirmation-message-value="ACTIVER LE MODE PANIQUE ? TOUTES LES OPÉRATIONS PUBLIQUES SERONT BLOQUÉES."
                  data-action="submit->confirmation#confirm">
                <button type="submit" class="px-4 py-2 bg-lab-danger/10 border border-lab-danger/40 text-lab-danger font-mono text-[10px] uppercase hover:bg-lab-danger hover:text-white transition-all">
                    Panic_Mode
                </button>
            </form>
        </div>
    </div>

    <!-- STATS GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 font-mono">
        <div class="admin-card p-6 relative overflow-hidden group">
            <div class="flex justify-between items-start mb-4">
                <span class="text-xs text-lab-muted uppercase tracking-widest">Utilisateurs</span>
                <i data-lucide="users" class="w-4 h-4 text-lab-primary"></i>
            </div>
            <div class="text-3xl font-bold text-white">{{ stats.total_users }}</div>
        </div>

        <div class="admin-card p-6 relative overflow-hidden group">
            <div class="flex justify-between items-start mb-4">
                <span class="text-xs text-lab-muted uppercase tracking-widest">Pipeline Leads</span>
                <i data-lucide="activity" class="w-4 h-4 text-lab-cyan"></i>
            </div>
            <div class="text-3xl font-bold text-white">{{ stats.total_leads }}</div>
        </div>

        <div class="admin-card p-6 relative overflow-hidden group">
            <div class="flex justify-between items-start mb-4">
                <span class="text-xs text-lab-muted uppercase tracking-widest">Rdv Aujourd'hui</span>
                <i data-lucide="calendar" class="w-4 h-4 text-lab-terminal"></i>
            </div>
            <div class="text-3xl font-bold text-white">{{ stats.today_appointments }}</div>
        </div>

        <div class="admin-card p-6 relative overflow-hidden group">
            <div class="flex justify-between items-start mb-4">
                <span class="text-xs text-lab-muted uppercase tracking-widest">Stations Lab</span>
                <i data-lucide="server" class="w-4 h-4 text-lab-warning"></i>
            </div>
            <div class="text-3xl font-bold text-white">{{ stats.active_stations }}</div>
        </div>
    </div>

    {% for flash in app.flashes('success') %}
        <div class="admin-card p-4 border-lab-terminal/30 bg-lab-terminal/5 text-[10px] font-mono text-lab-terminal uppercase">
            <i data-lucide="check-circle" class="w-4 h-4 inline mr-2"></i> {{ flash }}
        </div>
    {% endfor %}
    {% for flash in app.flashes('info') %}
        <div class="admin-card p-4 border-lab-primary/30 bg-lab-primary/5 text-[10px] font-mono text-lab-primary uppercase">
            <i data-lucide="info" class="w-4 h-4 inline mr-2"></i> {{ flash }}
        </div>
    {% endfor %}
    {% for flash in app.flashes('error') %}
        <div class="admin-card p-4 border-lab-danger/30 bg-lab-danger/5 text-[10px] font-mono text-lab-danger uppercase animate-pulse">
            <i data-lucide="alert-triangle" class="w-4 h-4 inline mr-2"></i> {{ flash }}
        </div>
    {% endfor %}

    <!-- PIPELINE SECTION (Kanban) - MISE EN AVANT -->
    <div class="admin-card p-6">
        <div class="flex items-center justify-between mb-6 border-b border-lab-border pb-4">
            <h2 class="text-sm font-bold text-white uppercase tracking-widest flex items-center gap-3">
                <i data-lucide="layout-list" class="w-4 h-4 text-lab-cyan"></i> Pipeline de Conversion
            </h2>
            <div class="flex items-center gap-2 text-[10px] font-mono text-lab-muted">
                <span class="uppercase">Sort:</span>
                <a href="{{ path('admin_dashboard', {sort: 'createdAt', direction: current_direction == 'DESC' ? 'ASC' : 'DESC'}) }}" class="hover:text-white underline">Date</a>
            </div>
        </div>

        <div class="flex gap-4 overflow-x-auto pb-4 min-h-[500px]">
            {% for status in statuses %}
                <div class="flex-shrink-0 w-80 flex flex-col admin-card !bg-black/40 border-lab-border/30">
                    <div class="p-3 border-b border-lab-border/50 flex items-center justify-between bg-black/60">
                        <div class="flex items-center gap-2">
                            <div class="w-1.5 h-1.5 rounded-full bg-lab-primary"></div>
                            <h3 class="text-[10px] font-mono font-bold text-white uppercase tracking-widest">{{ status.getLabel() }}</h3>
                        </div>
                        <span class="text-[10px] font-mono text-lab-muted">{{ grouped_leads[status.value]|length }}</span>
                    </div>

                    <div class="flex-1 p-2 space-y-3" 
                         data-kanban-target="column" 
                         data-status="{{ status.value }}">
                        {% for lead in grouped_leads[status.value] %}
                            {{ include('admin/leads/_card.html.twig', {lead: lead}) }}
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

    <!-- MAIN GRID CONTENT (JOURNAL + GRAPH) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 admin-card flex flex-col">
            <div class="p-6 border-b border-lab-border flex items-center justify-between">
                <h2 class="text-sm font-bold text-white uppercase tracking-widest flex items-center gap-3">
                    <i data-lucide="list" class="w-4 h-4 text-lab-primary"></i> Journal du Kernel
                </h2>
                <form method="post" action="{{ path('admin_clear_logs') }}" 
                      data-controller="confirmation"
                      data-confirmation-message-value="EFFACER DÉFINITIVEMENT TOUT LE REGISTRE DU KERNEL ?"
                      data-action="submit->confirmation#confirm">
                    <button type="submit" class="text-[10px] font-mono text-lab-muted hover:text-lab-primary transition-colors uppercase">Effacer les logs</button>
                </form>
            </div>
            <div class="p-6 overflow-y-auto max-h-[400px] font-mono text-[11px] space-y-4">
                {% for log in system_logs %}
                    <div class="flex gap-4 group">
                        <span class="text-lab-muted shrink-0">[{{ log.createdAt|date('H:i:s') }}]</span>
                        <span class="uppercase font-bold
                            {% if log.level == 'SUCCESS' %}text-lab-terminal
                            {% elseif log.level == 'ERROR' %}text-lab-danger
                            {% elseif log.level == 'SYSTEM' %}text-lab-primary
                            {% elseif log.level == 'WARNING' %}text-lab-warning
                            {% else %}text-lab-muted
                            {% endif %}">
                            {{ log.level }}
                        </span>
                        <span class="text-lab-text">
                            <span class="text-lab-muted">[{{ log.category }}]</span> {{ log.message }}
                        </span>
                    </div>
                {% else %}
                    <div class="flex items-center justify-center py-12 text-lab-muted italic uppercase tracking-widest opacity-50">
                        Aucun événement enregistré dans le registre noyau.
                    </div>
                {% endfor %}
            </div>
        </div>

        <!-- BARRE LATÉRALE -->
        <div class="space-y-6">
            <div class="admin-card p-6">
                <h2 class="text-sm font-bold text-white uppercase tracking-widest flex items-center gap-3 mb-6">
                    <i data-lucide="line-chart" class="w-4 h-4 text-lab-cyan"></i> Activité Leads (30j)
                </h2>
                <div class="h-40">
                    {{ render_chart(activity_chart) }}
                </div>
            </div>

            <div data-controller="pwa-notification"
                 data-pwa-notification-public-key-value="{{ vapid_public_key }}"
                 data-pwa-notification-subscribe-url-value="{{ path('api_admin_push_subscribe') }}">
                <div class="admin-card p-6 bg-lab-primary/5 border-lab-primary/20">
                    <h2 class="text-xs font-bold text-white uppercase tracking-widest flex items-center gap-3 mb-4">
                        <i data-lucide="bell-ring" class="w-4 h-4 text-lab-primary"></i> Alertes Push
                    </h2>
                    <p data-pwa-notification-target="status" class="text-[9px] font-mono text-lab-muted uppercase mb-4">Initialisation...</p>
                    <button data-action="click->pwa-notification#toggle" 
                            data-pwa-notification-target="button"
                            class="w-full text-[9px] font-mono font-bold text-lab-primary border border-lab-primary/50 py-2 hover:bg-lab-primary hover:text-black transition-all">
                        ACTIVER_LES_FLUX
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Side Panel Detail -->
    <div id="lead-detail-panel" class="fixed inset-y-0 right-0 z-[100] flex transform translate-x-full transition-transform duration-300 ease-in-out">
        <div class="w-screen h-full absolute inset-0 -left-full bg-black/60 opacity-0 pointer-events-none transition-opacity duration-300"
             id="lead-detail-overlay"
             data-action="click->kanban#hideDetails"></div>

        <div class="w-full max-w-lg bg-lab-panel border-l border-lab-border relative z-10 h-full shadow-[-20px_0_60px_rgba(0,0,0,0.8)]">
            <turbo-frame id="lead_detail" class="h-full">
                <!-- Content loaded here -->
            </turbo-frame>
        </div>
    </div>
</div>
{% endblock %}
