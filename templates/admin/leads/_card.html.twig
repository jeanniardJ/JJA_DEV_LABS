<div class="kanban-card group bg-lab-bg/80 border border-lab-border p-4 rounded-sm shadow-md hover:border-lab-primary/50 transition-all cursor-grab active:cursor-grabbing relative overflow-hidden" 
     data-id="{{ lead.id }}"
     data-action="click->kanban#showDetails">
    
    <!-- Source Accent -->
    <div class="absolute top-0 left-0 w-[2px] h-full {% if lead.subject matches '/Analyse/' %}bg-lab-primary{% else %}bg-lab-terminal{% endif %}"></div>

    <div class="flex flex-col gap-2">
        <div class="flex items-start justify-between">
            <h3 class="text-xs font-bold text-white font-mono truncate pr-4">{{ lead.name }}</h3>
            <div class="text-[8px] text-lab-muted font-mono uppercase">{{ lead.createdAt|date('d/m/Y') }}</div>
        </div>
        
        <p class="text-[10px] text-lab-text font-mono line-clamp-2 leading-relaxed opacity-80">
            {{ lead.subject }}
        </p>

        <div class="flex items-center justify-between mt-2 pt-2 border-t border-lab-border/30">
            <div class="flex items-center gap-2">
                <i data-lucide="mail" class="w-3 h-3 text-lab-muted"></i>
                <span class="text-[9px] text-lab-muted font-mono truncate max-w-[120px]">{{ lead.email }}</span>
            </div>
            
            {% if lead.appointments|length > 0 %}
                <div class="flex items-center gap-1 text-lab-terminal">
                    <i data-lucide="calendar" class="w-3 h-3"></i>
                    <span class="text-[8px] font-mono font-bold">RDV</span>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Hover Indicator -->
    <div class="absolute bottom-1 right-1 opacity-0 group-hover:opacity-100 transition-opacity">
        <i data-lucide="move" class="w-3 h-3 text-lab-muted"></i>
    </div>
</div>
