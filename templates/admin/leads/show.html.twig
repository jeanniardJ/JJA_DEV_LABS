<turbo-frame id="lead_detail">
    <div class="h-full flex flex-col">
        <!-- Detail Header -->
        <div class="p-6 border-b border-lab-border flex items-center justify-between bg-black/20">
            <div>
                <h2 class="text-lg font-bold text-white font-mono uppercase">{{ lead.name }}</h2>
                <div class="flex items-center gap-2 mt-1">
                    <span class="text-[9px] font-mono text-lab-muted">ID: #{{ lead.id }}</span>
                    <span class="w-1 h-1 rounded-full bg-lab-border"></span>
                    <span class="text-[9px] font-mono text-lab-primary uppercase">{{ lead.status.getLabel() }}</span>
                </div>
            </div>
            <button data-action="click->kanban#hideDetails" class="text-lab-muted hover:text-white p-2">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>

        <!-- Detail Content -->
        <div class="flex-1 overflow-y-auto p-6 space-y-8">
            <!-- Contact Info -->
            <section class="space-y-4">
                <h3 class="text-[10px] font-mono font-bold text-lab-muted uppercase tracking-widest">INFOS_CONTACT</h3>
                <div class="grid grid-cols-1 gap-4">
                    <div class="bg-black/30 border border-lab-border p-3 rounded-sm">
                        <p class="text-[8px] text-lab-muted font-mono uppercase">Email</p>
                        <p class="text-xs text-lab-terminal font-mono mt-1">{{ lead.email }}</p>
                    </div>
                    <div class="bg-black/30 border border-lab-border p-3 rounded-sm">
                        <p class="text-[8px] text-lab-muted font-mono uppercase">Message Initial</p>
                        <p class="text-xs text-lab-text font-mono mt-2 leading-relaxed whitespace-pre-wrap">{{ lead.message }}</p>
                    </div>
                </div>
            </section>

            <!-- Activity Timeline -->
            <section class="space-y-6">
                <h3 class="text-[10px] font-mono font-bold text-lab-muted uppercase tracking-widest">TIMELINE_ACTIVITÉ</h3>
                
                <div class="relative pl-6 space-y-8 before:absolute before:left-2 before:top-2 before:bottom-2 before:w-[1px] before:bg-lab-border">
                    {% for event in events %}
                        <div class="relative">
                            <!-- Timeline Dot -->
                            <div class="absolute -left-[21px] top-1 w-3 h-3 rounded-full bg-lab-bg border border-{{ event.color }} flex items-center justify-center z-10">
                                <div class="w-1 h-1 rounded-full bg-{{ event.color }}"></div>
                            </div>

                            <div class="flex flex-col gap-1">
                                <div class="flex items-center gap-2">
                                    <i data-lucide="{{ event.icon }}" class="w-3 h-3 text-{{ event.color }}"></i>
                                    <span class="text-[10px] font-bold text-white font-mono uppercase">{{ event.label }}</span>
                                </div>
                                <span class="text-[8px] text-lab-muted font-mono">{{ event.date|date('d M Y, H:i') }}</span>
                                
                                {% if event.link is defined %}
                                    <a href="{{ event.link }}" class="text-[9px] text-lab-primary hover:underline font-mono mt-1 flex items-center gap-1">
                                        [ VOIR_LE_DOCUMENT ]
                                        <i data-lucide="external-link" class="w-2 h-2"></i>
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </section>

            <!-- AI Assistant Section -->
            <section class="pt-8 border-t border-lab-border/30" 
                     data-controller="ai-assistant"
                     data-ai-assistant-generate-url-value="{{ path('admin_ai_generate', {id: lead.id}) }}"
                     data-ai-assistant-send-url-value="{{ path('admin_ai_send', {id: lead.id}) }}">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-[10px] font-mono font-bold text-lab-primary uppercase tracking-widest flex items-center gap-2">
                        <i data-lucide="sparkles" class="w-3 h-3"></i>
                        ASSISTANT_DE_REPONSE_IA
                    </h3>
                    <button data-action="click->ai-assistant#generate" 
                            data-ai-assistant-target="button"
                            class="text-[9px] font-mono font-bold text-white bg-lab-primary/20 border border-lab-primary/50 px-3 py-1 hover:bg-lab-primary/40 transition-all disabled:opacity-50">
                        GÉNÉRER_BROUILLON
                    </button>
                </div>

                <div data-ai-assistant-target="loader" class="hidden mb-4 space-y-3">
                    <div class="flex items-center gap-2 text-[10px] text-lab-primary font-mono animate-pulse">
                        <i data-lucide="brain" class="w-4 h-4"></i>
                        ANALYSE_DU_CONTEXTE_ET_GENERATION_EN_COURS...
                    </div>
                    <!-- Skeleton effect -->
                    <div class="space-y-2 opacity-20">
                        <div class="h-2 bg-lab-primary w-full rounded-full animate-pulse"></div>
                        <div class="h-2 bg-lab-primary w-5/6 rounded-full animate-pulse delay-75"></div>
                        <div class="h-2 bg-lab-primary w-4/6 rounded-full animate-pulse delay-150"></div>
                    </div>
                </div>

                <div data-ai-assistant-target="container" class="hidden space-y-4">
                    <div class="relative">
                        <textarea data-ai-assistant-target="draftArea" 
                                  class="w-full bg-black/40 border border-lab-primary/30 p-4 text-xs text-lab-text font-mono focus:border-lab-primary outline-none min-h-[150px] transition-all"
                                  placeholder="Le brouillon apparaîtra ici..."></textarea>
                        <div class="absolute top-2 right-2">
                            <i data-lucide="wand-2" class="w-4 h-4 text-lab-primary/30"></i>
                        </div>
                    </div>
                    
                    <div class="flex justify-end">
                        <button data-action="click->ai-assistant#send"
                                data-ai-assistant-target="sendButton"
                                class="bg-lab-primary text-black font-mono font-black uppercase text-[10px] px-6 py-2 hover:bg-lab-cyan transition-all">
                            ENVOYER_LA_RÉPONSE
                        </button>
                    </div>
                </div>
            </section>
        </div>

        <!-- Footer Actions -->
        <div class="p-6 border-t border-lab-border bg-black/20 flex gap-3">
            <a href="mailto:{{ lead.email }}" class="flex-1 py-3 bg-lab-primary text-black font-mono font-black uppercase text-[10px] text-center hover:bg-lab-cyan transition-all">
                REPONDRE_VIA_EMAIL
            </a>
            <button class="p-3 border border-lab-border text-lab-muted hover:text-lab-danger hover:border-lab-danger transition-colors">
                <i data-lucide="trash-2" class="w-4 h-4"></i>
            </button>
        </div>
    </div>
</turbo-frame>
