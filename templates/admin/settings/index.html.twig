{% extends 'admin/layout.html.twig' %}

{% block title %}PARAMÈTRES SYSTÈME | JJA DEV LAB{% endblock %}

{% block admin_breadcrumb %}Configuration du Noyau{% endblock %}

{% block admin_body %}
    <div class="space-y-8">
        <!-- HEADER -->
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h1 class="text-3xl font-black text-white uppercase tracking-tighter leading-none">Kernel Settings</h1>
                <p class="text-lab-muted font-mono text-xs mt-2 uppercase tracking-widest">Modification des variables d'environnement et paramètres de service</p>
            </div>
        </div>

        {% for flash in app.flashes('success') %}
            <div class="admin-card p-4 border-lab-terminal/30 bg-lab-terminal/5 text-[10px] font-mono text-lab-terminal uppercase">
                <i data-lucide="check-circle" class="w-4 h-4 inline mr-2"></i> {{ flash }}
            </div>
        {% endfor %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- CONFIGURATION DYNAMIQUE -->
            <div class="lg:col-span-2 space-y-6">
                <div class="admin-card">
                    <div class="p-6 border-b border-lab-border flex items-center justify-between">
                        <h2 class="text-sm font-bold text-white uppercase tracking-widest flex items-center gap-3">
                            <i data-lucide="settings-2" class="w-4 h-4 text-lab-primary"></i> Registre de Configuration
                        </h2>
                    </div>
                    <div class="p-0">
                        <table class="w-full text-left font-mono text-[11px]">
                            <thead>
                                <tr class="border-b border-lab-border bg-black/40 text-lab-muted uppercase tracking-widest">
                                    <th class="px-6 py-4 font-bold">Variable</th>
                                    <th class="px-6 py-4 font-bold">Valeur actuelle</th>
                                    <th class="px-6 py-4 font-bold text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-lab-border/30">
                                {% for config in configs %}
                                    <tr class="hover:bg-lab-primary/5 transition-colors">
                                        <td class="px-6 py-4">
                                            <div class="text-white font-bold">{{ config.settingKey }}</div>
                                            <div class="text-[9px] text-lab-muted uppercase mt-1">{{ config.description }}</div>
                                        </td>
                                        <td class="px-6 py-4 text-lab-text italic">
                                            {% if edit_id == config.id %}
                                                {{ form_start(edit_form) }}
                                                    {{ form_widget(edit_form.settingValue) }}
                                                    <div class="flex gap-2 mt-2">
                                                        <button type="submit" class="px-3 py-1 bg-lab-terminal text-black text-[9px] uppercase font-bold">Sauvegarder</button>
                                                        <a href="{{ path('admin_settings_index') }}" class="px-3 py-1 border border-lab-border text-lab-muted text-[9px] uppercase font-bold">Annuler</a>
                                                    </div>
                                                {{ form_end(edit_form) }}
                                            {% else %}
                                                {{ config.settingValue|length > 100 ? config.settingValue|slice(0, 100) ~ '...' : config.settingValue }}
                                            {% endif %}
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            {% if edit_id != config.id %}
                                                <a href="{{ path('admin_settings_index', {edit: config.id}) }}" class="text-lab-primary hover:underline uppercase text-[10px]">Éditer</a>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="3" class="px-6 py-12 text-center text-lab-muted italic uppercase">
                                            Aucune variable configurée. Exécutez le seeder ou ajoutez-les manuellement.
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ÉTAT DU SYSTÈME (LECTURE SEULE) -->
            <div class="lg:col-span-1 space-y-6">
                <div class="admin-card p-6">
                    <h2 class="text-sm font-bold text-white uppercase tracking-widest flex items-center gap-3 mb-6">
                        <i data-lucide="shield-check" class="w-4 h-4 text-lab-terminal"></i> État du Système
                    </h2>
                    
                    <div class="space-y-4 font-mono text-[10px]">
                        <div class="flex justify-between border-b border-lab-border pb-2">
                            <span class="text-lab-muted uppercase">Base de données</span>
                            <span class="{% if db_status %}text-lab-terminal{% else %}text-lab-danger{% endif %} font-bold">
                                {{ db_status ? 'ONLINE' : 'OFFLINE' }}
                            </span>
                        </div>
                        <div class="flex justify-between border-b border-lab-border pb-2">
                            <span class="text-lab-muted uppercase">Version PHP</span>
                            <span class="text-white font-bold">{{ php_version }}</span>
                        </div>
                        <div class="flex justify-between border-b border-lab-border pb-2">
                            <span class="text-lab-muted uppercase">Environnement</span>
                            <span class="text-lab-warning font-bold uppercase">{{ env }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-lab-muted uppercase">Débug Mode</span>
                            <span class="text-lab-primary font-bold">{{ app.debug ? 'ACTIF' : 'INACTIF' }}</span>
                        </div>
                    </div>
                </div>

                <div class="admin-card p-6 border-lab-warning/20 bg-lab-warning/5">
                    <div class="flex items-center gap-2 text-[10px] text-lab-warning font-bold uppercase tracking-widest mb-4">
                        <i data-lucide="alert-triangle" class="w-3 h-3"></i> Avertissement
                    </div>
                    <p class="text-[9px] text-lab-muted font-mono leading-relaxed uppercase">
                        La modification du Registre de Configuration peut altérer le comportement des services vitaux (Emails, IA, Sécurité). Procédez avec prudence.
                    </p>
                </div>
            </div>

        </div>
    </div>
{% endblock %}
