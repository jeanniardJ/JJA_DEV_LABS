{% extends 'admin/layout.html.twig' %}

{% block title %}JJA DEV LAB | Utilisateurs{% endblock %}

{% block admin_breadcrumb %}Utilisateurs{% endblock %}

{% block admin_body %}
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-3xl font-black text-white uppercase tracking-tighter leading-none">Opérateurs Enregistrés</h1>
            <p class="text-lab-muted font-mono text-xs mt-2 uppercase tracking-widest">Gestion des accès et niveaux d'habilitation</p>
        </div>
        <div class="text-[10px] font-mono text-lab-muted uppercase">
            {{ users|length }} utilisateur{{ users|length > 1 ? 's' : '' }} enregistré{{ users|length > 1 ? 's' : '' }}
        </div>
    </div>

    {% for flash in app.flashes('success') %}
        <div class="admin-card p-4 border-lab-terminal/30 bg-lab-terminal/5">
            <div class="flex items-center gap-3 text-[10px] font-mono text-lab-terminal uppercase tracking-widest">
                <i data-lucide="check-circle" class="w-4 h-4"></i> {{ flash }}
            </div>
        </div>
    {% endfor %}
    {% for flash in app.flashes('error') %}
        <div class="admin-card p-4 border-lab-danger/30 bg-lab-danger/5">
            <div class="flex items-center gap-3 text-[10px] font-mono text-lab-danger uppercase tracking-widest">
                <i data-lucide="alert-circle" class="w-4 h-4"></i> {{ flash }}
            </div>
        </div>
    {% endfor %}

    <div class="admin-card">
        <div class="p-6 border-b border-lab-border flex items-center gap-3">
            <h2 class="text-sm font-bold text-white uppercase tracking-widest flex items-center gap-3">
                <i data-lucide="users" class="w-4 h-4 text-lab-primary"></i> Registry des Opérateurs
            </h2>
        </div>

        <div class="divide-y divide-lab-border/30">
            {% for user in users %}
                <div class="p-6 flex flex-col md:flex-row md:items-center justify-between gap-4 hover:bg-white/[0.02] transition-colors">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 border {% if 'ROLE_ADMIN' in user.roles %}border-lab-terminal bg-lab-terminal/10{% else %}border-lab-border bg-black/20{% endif %} flex items-center justify-center flex-shrink-0">
                            <i data-lucide="{% if 'ROLE_ADMIN' in user.roles %}shield{% else %}user{% endif %}" class="w-4 h-4 {% if 'ROLE_ADMIN' in user.roles %}text-lab-terminal{% else %}text-lab-muted{% endif %}"></i>
                        </div>
                        <div>
                            <div class="flex items-center gap-3">
                                <span class="text-sm font-bold text-white font-mono">{{ user.email }}</span>
                                {% if user == app.user %}
                                    <span class="px-2 py-0.5 text-[8px] font-mono uppercase tracking-widest bg-lab-primary/10 text-lab-primary border border-lab-primary/30">Vous</span>
                                {% endif %}
                            </div>
                            <div class="flex items-center gap-3 mt-1">
                                {% for role in user.roles %}
                                    <span class="text-[9px] font-mono uppercase tracking-widest
                                        {% if role == 'ROLE_ADMIN' %}text-lab-terminal
                                        {% else %}text-lab-muted
                                        {% endif %}">{{ role }}</span>
                                {% endfor %}
                            </div>
                            <div class="flex items-center gap-4 mt-1 text-[9px] font-mono text-lab-muted/50">
                                {% if user.googleId %}
                                    <span class="flex items-center gap-1"><i data-lucide="chrome" class="w-3 h-3"></i> Google SSO</span>
                                {% endif %}
                                {% if user.googleAuthenticatorSecret %}
                                    <span class="flex items-center gap-1 text-lab-terminal/50"><i data-lucide="shield-check" class="w-3 h-3"></i> 2FA Actif</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {% if user != app.user %}
                        <div class="flex items-center gap-2 flex-shrink-0">
                            <form method="post" action="{{ path('admin_user_toggle_admin', {id: user.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                                {% if 'ROLE_ADMIN' in user.roles %}
                                    <button type="submit" class="px-3 py-1.5 border border-lab-warning/30 text-lab-warning text-[9px] font-mono uppercase hover:bg-lab-warning/10 transition-all" title="Retirer Admin">
                                        <i data-lucide="shield-off" class="w-3 h-3 inline"></i> Révoquer
                                    </button>
                                {% else %}
                                    <button type="submit" class="px-3 py-1.5 border border-lab-terminal/30 text-lab-terminal text-[9px] font-mono uppercase hover:bg-lab-terminal/10 transition-all" title="Promouvoir Admin">
                                        <i data-lucide="shield" class="w-3 h-3 inline"></i> Promouvoir
                                    </button>
                                {% endif %}
                            </form>
                            <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}" onsubmit="return confirm('Supprimer cet utilisateur ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                <button type="submit" class="px-3 py-1.5 border border-lab-danger/30 text-lab-danger text-[9px] font-mono uppercase hover:bg-lab-danger/10 transition-all">
                                    <i data-lucide="trash-2" class="w-3 h-3"></i>
                                </button>
                            </form>
                        </div>
                    {% endif %}
                </div>
            {% else %}
                <div class="p-12 text-center">
                    <i data-lucide="user-x" class="w-8 h-8 text-lab-border mx-auto mb-4"></i>
                    <p class="text-lab-muted font-mono text-xs uppercase tracking-widest">Aucun utilisateur enregistré</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
