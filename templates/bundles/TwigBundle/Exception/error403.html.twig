{% extends 'base.html.twig' %}

{% block title %}JJA DEV LAB | ACCESS DENIED{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .error-card {
            background: rgba(11, 15, 20, 0.9);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 51, 102, 0.2);
            box-shadow: 0 0 50px rgba(255, 51, 102, 0.1);
        }

        .glitch-hover:hover {
            animation: glitch 0.2s infinite;
        }

        @keyframes glitch {
            0% { transform: translate(0); }
            25% { transform: translate(-2px, 2px); }
            50% { transform: translate(2px, -2px); }
            75% { transform: translate(-1px, -1px); }
            100% { transform: translate(0); }
        }
    </style>
{% endblock %}

{% block header %}
    <header class="fixed top-0 w-full z-40 p-6 flex justify-between items-center pointer-events-none">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-lab-danger/10 border border-lab-danger flex items-center justify-center">
                <i data-lucide="lock" class="w-4 h-4 text-lab-danger animate-pulse"></i>
            </div>
            <div class="flex flex-col leading-none">
                <span class="font-bold tracking-widest text-white text-sm uppercase">JJA LAB</span>
                <span class="text-[10px] text-lab-danger font-mono uppercase tracking-[0.2em] mt-1">Status: Security_Breach</span>
            </div>
        </div>
    </header>
{% endblock %}

{% block body %}
    <div class="min-h-[70vh] flex items-center justify-center">
        <main class="error-card w-full max-w-lg rounded-sm p-10 relative overflow-hidden animate-float">
            
            <div class="absolute top-0 right-0 w-16 h-16 pointer-events-none opacity-40">
                <div class="absolute top-0 right-0 w-full h-[2px] bg-lab-danger"></div>
                <div class="absolute top-0 right-0 w-[2px] h-full bg-lab-danger"></div>
            </div>

            <div class="flex flex-col items-center text-center">
                <h1 class="text-8xl md:text-9xl font-black text-white tracking-tighter mb-2 opacity-90 glitch-hover cursor-default">403</h1>
                
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-lab-danger/10 border border-lab-danger/30 text-lab-danger text-[10px] font-mono tracking-widest uppercase rounded-sm mb-8">
                    <i data-lucide="shield-alert" class="w-3 h-3"></i> Erreur : ACCESS_DENIED
                </div>

                <p class="text-lab-text font-mono text-sm leading-relaxed mb-8 max-w-sm italic">
                    // Accès refusé. Vos privilèges actuels ne vous permettent pas d'entrer dans ce secteur du laboratoire. Incident consigné.
                </p>

                <div class="w-full bg-black/50 border border-lab-border p-4 rounded-sm mb-10 text-left font-mono text-[10px] text-lab-muted space-y-1">
                    <div>[0.10045] AUTH: Validating token privileges... <span class="text-lab-danger">FAILED</span></div>
                    <div>[0.10047] SEC: Unauthorized access attempt blocked</div>
                    <div>[0.10049] INFO: Logging IP and terminal metadata... <span class="text-lab-terminal">DONE</span></div>
                    <div class="pt-2"><span class="text-lab-danger">></span> exit --secure <span class="animate-blink">_</span></div>
                </div>

                <a href="{{ path('app_home') }}" class="group relative px-8 py-4 bg-white text-black font-mono font-black uppercase text-xs tracking-[0.2em] hover:bg-lab-primary hover:text-white transition-all shadow-lg flex items-center justify-center gap-3 rounded-sm">
                    <i data-lucide="corner-down-left" class="w-4 h-4 group-hover:-translate-x-1 transition-transform duration-300"></i>
                    Quitter_Zone_Restreinte
                </a>
            </div>
        </main>
    </div>
{% endblock %}

{% block footer %}
    <footer class="fixed bottom-6 left-0 w-full flex flex-col items-center gap-4 pointer-events-none z-30">
        <div class="flex gap-10 opacity-20 text-lab-muted font-mono text-[10px] uppercase tracking-[0.4em]">
            <span>Dump : Auth_Log_03</span>
            <span class="hidden md:block">Node : Firewall_Gateway</span>
            <span>Uptime : --:--:--</span>
        </div>
    </footer>
{% endblock %}
