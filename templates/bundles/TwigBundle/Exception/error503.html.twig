{% extends 'base.html.twig' %}

{% block title %}JJA DEV LAB | SERVICE UNAVAILABLE{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .error-card {
            background: rgba(11, 15, 20, 0.9);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 204, 0, 0.2); /* Jaune/Orange pour la maintenance */
            box-shadow: 0 0 50px rgba(255, 204, 0, 0.1);
        }

        .text-lab-warning {
            color: #ffcc00;
        }

        .border-lab-warning {
            border-color: #ffcc00;
        }

        .bg-lab-warning {
            background-color: #ffcc00;
        }

        .glitch-hover:hover {
            animation: glitch 0.2s infinite;
        }

        @keyframes glitch {
            0% { transform: translate(0); }
            25% { transform: translate(-2px, 2px); }
            50% { transform: translate(2px, -2px); }
            75% { transform: translate(-1px, -1px); }
            100% { transform: translate(0); }
        }
    </style>
{% endblock %}

{% block header %}
    <header class="fixed top-0 w-full z-40 p-6 flex justify-between items-center pointer-events-none">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-lab-warning/10 border border-lab-warning flex items-center justify-center">
                <i data-lucide="settings" class="w-4 h-4 text-lab-warning animate-spin"></i>
            </div>
            <div class="flex flex-col leading-none">
                <span class="font-bold tracking-widest text-white text-sm uppercase">JJA LAB</span>
                <span class="text-[10px] text-lab-warning font-mono uppercase tracking-[0.2em] mt-1">Status: System_Maintenance</span>
            </div>
        </div>
    </header>
{% endblock %}

{% block body %}
    <div class="min-h-[70vh] flex items-center justify-center">
        <main class="error-card w-full max-w-lg rounded-sm p-10 relative overflow-hidden animate-float">
            
            <div class="absolute top-0 right-0 w-16 h-16 pointer-events-none opacity-40">
                <div class="absolute top-0 right-0 w-full h-[2px] bg-lab-warning"></div>
                <div class="absolute top-0 right-0 w-[2px] h-full bg-lab-warning"></div>
            </div>

            <div class="flex flex-col items-center text-center">
                <h1 class="text-8xl md:text-9xl font-black text-white tracking-tighter mb-2 opacity-90 glitch-hover cursor-default">503</h1>
                
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-lab-warning/10 border border-lab-warning/30 text-lab-warning text-[10px] font-mono tracking-widest uppercase rounded-sm mb-8">
                    <i data-lucide="hard-drive" class="w-3 h-3"></i> État : SERVICE_UNAVAILABLE
                </div>

                <p class="text-lab-text font-mono text-sm leading-relaxed mb-8 max-w-sm italic">
                    // Le laboratoire est actuellement hors ligne. Déploiement de nouveaux modules de sécurité ou réallocation des ressources en cours.
                </p>

                <div class="w-full bg-black/50 border border-lab-border p-4 rounded-sm mb-10 text-left font-mono text-[10px] text-lab-muted space-y-1">
                    <div>[0.44210] SYS: Pausing incoming connections... <span class="text-lab-warning">HOLD</span></div>
                    <div>[0.44212] INFO: Running diagnostic tools</div>
                    <div>[0.44215] UPDATE: Applying latest kernel patches...</div>
                    <div class="pt-2"><span class="text-lab-warning">></span> wait --timeout=auto <span class="animate-blink">_</span></div>
                </div>

                <a href="{{ path('app_home') }}" class="group relative px-8 py-4 bg-white text-black font-mono font-black uppercase text-xs tracking-[0.2em] hover:bg-lab-primary hover:text-white transition-all shadow-lg flex items-center justify-center gap-3 rounded-sm">
                    <i data-lucide="refresh-cw" class="w-4 h-4 group-hover:rotate-180 transition-transform duration-500"></i>
                    Tenter_Reconnexion
                </a>
            </div>
        </main>
    </div>
{% endblock %}

{% block footer %}
    <footer class="fixed bottom-6 left-0 w-full flex flex-col items-center gap-4 pointer-events-none z-30">
        <div class="flex gap-10 opacity-20 text-lab-muted font-mono text-[10px] uppercase tracking-[0.4em]">
            <span>Dump : Null_Route</span>
            <span class="hidden md:block">Node : Main_Server</span>
            <span>Uptime : --:--:--</span>
        </div>
    </footer>
{% endblock %}
