{% extends 'base.html.twig' %}

{% block title %}JJA DEV LAB | Lab Stations{% endblock %}

{% block body %}
    <!-- HEADER DE LA PAGE -->
    <section class="mb-12 border-b border-lab-primary/50 pb-4">
        <h1 class="text-3xl md:text-4xl font-bold text-white flex items-center gap-4">
            <i data-lucide="layout-dashboard" class="w-8 h-8 text-lab-cyan"></i>
            <span class="glow-text">LAB STATION OPERATOR DASHBOARD</span>
        </h1>
        <p class="text-lab-muted font-mono mt-2 text-sm">
            /root/lab-modules/status: Monitoring 7 critical lab environments. All systems nominal.
        </p>
    </section>

    <!-- GRID PRINCIPALE DES STATIONS -->
    <section class="grid grid-cols-1 lg:grid-cols-3 xl:grid-cols-4 gap-6">

        <!-- STATUT GÉNÉRAL (COL SPAN) -->
        <div class="lg:col-span-3 xl:col-span-4 glass-panel border border-lab-border p-6 rounded-sm mb-4">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-lg font-bold text-white flex items-center gap-2">
                    <i data-lucide="activity" class="w-5 h-5 text-lab-terminal"></i> Global System Health
                </h2>
                <span class="text-xs font-mono text-lab-terminal">
                    Last Update: {{ "now"|date("Y/m/d H:i:s") }} UTC
                </span>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-xs font-mono">
                <div class="p-3 bg-lab-panel/50 border border-lab-border rounded-sm">
                    <div class="text-lab-muted">CPU Load (Avg)</div>
                    <div class="text-white text-lg">2.1%</div>
                </div>
                <div class="p-3 bg-lab-panel/50 border border-lab-border rounded-sm">
                    <div class="text-lab-muted">Memory Usage</div>
                    <div class="text-white text-lg">3.4 GB</div>
                </div>
                <div class="p-3 bg-lab-panel/50 border border-lab-border rounded-sm">
                    <div class="text-lab-muted">Network I/O</div>
                    <div class="text-white text-lg">1.2 MB/s</div>
                </div>
                <div class="p-3 bg-lab-panel/50 border border-lab-border rounded-sm">
                    <div class="text-lab-muted">Active Containers</div>
                    <div class="text-lab-primary text-lg">4/7</div>
                </div>
            </div>
        </div>


        <!-- CARD: Symfony Test Bench -->
        <article class="status-card bg-lab-panel border border-lab-border p-5 rounded-sm flex flex-col justify-between" style="border-left-color: #00c6ff;">
            <div>
                <div class="flex items-center justify-between mb-3">
                    <span class="text-lab-primary"><i data-lucide="flask-conical" class="w-6 h-6"></i></span>
                    <span class="text-xs font-mono text-lab-terminal">NOMINAL</span>
                </div>
                <h3 class="font-bold text-white text-base mb-1">Symfony Test Bench</h3>
                <p class="text-xs text-lab-muted">Testing stateful components and new routing logic.</p>
            </div>
            <div class="mt-4 pt-3 border-t border-lab-border/50 text-xs font-mono">
                <div class="text-lab-muted">Uptime: 45 days</div>
                <div class="text-lab-primary">Code Coverage: 85%</div>
            </div>
        </article>

        <!-- CARD: Security Playground -->
        <article class="status-card bg-lab-panel border border-lab-border p-5 rounded-sm flex flex-col justify-between" style="border-left-color: #ff3366;">
            <div>
                <div class="flex items-center justify-between mb-3">
                    <span class="text-lab-danger"><i data-lucide="shield-alert" class="w-6 h-6"></i></span>
                    <span class="text-xs font-mono text-lab-danger animate-pulse">WARNING</span>
                </div>
                <h3 class="font-bold text-white text-base mb-1">Security Playground</h3>
                <p class="text-xs text-lab-muted">Active fuzzing running against the JWT module endpoint.</p>
            </div>
            <div class="mt-4 pt-3 border-t border-lab-border/50 text-xs font-mono">
                <div class="text-lab-muted">Target: /api/auth</div>
                <div class="text-lab-danger">Last Vulnerability: CSRF (mitigated)</div>
            </div>
        </article>

        <!-- CARD: Docker/Devcontainer Lab -->
        <article class="status-card bg-lab-panel border border-lab-border p-5 rounded-sm flex flex-col justify-between" style="border-left-color: #4df4ff;">
            <div>
                <div class="flex items-center justify-between mb-3">
                    <span class="text-lab-cyan"><i data-lucide="container" class="w-6 h-6"></i></span>
                    <span class="text-xs font-mono text-lab-terminal">NOMINAL</span>
                </div>
                <h3 class="font-bold text-white text-base mb-1">Docker / LXC Lab</h3>
                <p class="text-xs text-lab-muted">Image optimization and multi-architecture build definitions.</p>
            </div>
            <div class="mt-4 pt-3 border-t border-lab-border/50 text-xs font-mono">
                <div class="text-lab-muted">Images: 12</div>
                <div class="text-lab-cyan">Latest Build: 3 hours ago</div>
            </div>
        </article>

        <!-- CARD: Automation & Scripts -->
        <article class="status-card bg-lab-panel border border-lab-border p-5 rounded-sm flex flex-col justify-between" style="border-left-color: #00ff88;">
            <div>
                <div class="flex items-center justify-between mb-3">
                    <span class="text-lab-terminal"><i data-lucide="zap" class="w-6 h-6"></i></span>
                    <span class="text-xs font-mono text-lab-terminal">RUNNING</span>
                </div>
                <h3 class="font-bold text-white text-base mb-1">Automation & Scripts</h3>
                <p class="text-xs text-lab-muted">Monitoring crons and CI/CD webhook listeners.</p>
            </div>
            <div class="mt-4 pt-3 border-t border-lab-border/50 text-xs font-mono">
                <div class="text-lab-muted">Jobs Queued: 0</div>
                <div class="text-lab-terminal">Last Job: Success</div>
            </div>
        </article>

        <!-- CARD: Technical Notes -->
        <article class="status-card bg-lab-panel border border-lab-border p-5 rounded-sm flex flex-col justify-between" style="border-left-color: #a855f7;">
            <div>
                <div class="flex items-center justify-between mb-3">
                    <span class="text-purple-400"><i data-lucide="file-code" class="w-6 h-6"></i></span>
                    <span class="text-xs font-mono text-lab-terminal">NOMINAL</span>
                </div>
                <h3 class="font-bold text-white text-base mb-1">Technical Notes</h3>
                <p class="text-xs text-lab-muted">Scratchpad and persistent command history.</p>
            </div>
            <div class="mt-4 pt-3 border-t border-lab-border/50 text-xs font-mono">
                <div class="text-lab-muted">Total Pages: 42</div>
                <div class="text-purple-400">Last Edit: 15 min ago</div>
            </div>
        </article>

            <!-- CARD: Architecture Sandbox -->
        <article class="status-card bg-lab-panel border border-lab-border p-5 rounded-sm flex flex-col justify-between" style="border-left-color: #fde047;">
            <div>
                <div class="flex items-center justify-between mb-3">
                    <span class="text-yellow-400"><i data-lucide="boxes" class="w-6 h-6"></i></span>
                    <span class="text-xs font-mono text-lab-muted">IDLE</span>
                </div>
                <h3 class="font-bold text-white text-base mb-1">Architecture Sandbox</h3>
                <p class="text-xs text-lab-muted">Conceptual diagrams, PoC for microservices communication.</p>
            </div>
            <div class="mt-4 pt-3 border-t border-lab-border/50 text-xs font-mono">
                <div class="text-lab-muted">Activity: Low</div>
                <div class="text-yellow-400">Project: Queue-Processor</div>
            </div>
        </article>

        <!-- CARD: OSINT / Exploration -->
        <article class="status-card bg-lab-panel border border-lab-border p-5 rounded-sm flex flex-col justify-between" style="border-left-color: #34d399;">
            <div>
                <div class="flex items-center justify-between mb-3">
                    <span class="text-emerald-400"><i data-lucide="globe" class="w-6 h-6"></i></span>
                    <span class="text-xs font-mono text-lab-terminal">NOMINAL</span>
                </div>
                <h3 class="font-bold text-white text-base mb-1">OSINT / Exploration</h3>
                <p class="text-xs text-lab-muted">External data processing tools and reconnaissance scripts.</p>
            </div>
            <div class="mt-4 pt-3 border-t border-lab-border/50 text-xs font-mono">
                <div class="text-lab-muted">Jobs Started: 5</div>
                <div class="text-emerald-400">Last Scan: Success</div>
            </div>
        </article>

    </section>
{% endblock %}
