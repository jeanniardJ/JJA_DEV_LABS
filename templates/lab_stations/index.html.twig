{% extends 'admin/layout.html.twig' %}

{% block title %}JJA DEV LAB | Lab Stations{% endblock %}

{% block admin_breadcrumb %}Skill Nodes{% endblock %}

{% block admin_body %}
    <!-- HEADER DE LA PAGE -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-3xl font-black text-white uppercase tracking-tighter leading-none">Lab Station Operator</h1>
            <p class="text-lab-muted font-mono text-xs mt-2 uppercase tracking-widest">Monitoring critical lab environments. All systems nominal.</p>
        </div>
    </div>

    <!-- GRID PRINCIPALE DES STATIONS -->
    <div class="space-y-8">

        <!-- STATUT GÉNÉRAL -->
        <div class="admin-card p-6 rounded-sm">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-sm font-bold text-white uppercase tracking-widest flex items-center gap-3">
                    <i data-lucide="activity" class="w-4 h-4 text-lab-terminal"></i> Global System Health
                </h2>
                <span class="text-[10px] font-mono text-lab-terminal uppercase">
                    Last Update: {{ "now"|date("Y/m/d H:i:s") }} UTC
                </span>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-[10px] font-mono uppercase">
                <div class="p-4 bg-black/20 border border-lab-border rounded-sm group hover:border-lab-primary transition-colors">
                    <div class="text-lab-muted mb-1">CPU Load (Avg)</div>
                    <div class="text-white text-lg font-bold">2.1%</div>
                </div>
                <div class="p-4 bg-black/20 border border-lab-border rounded-sm group hover:border-lab-warning transition-colors">
                    <div class="text-lab-muted mb-1">Memory Usage</div>
                    <div class="text-white text-lg font-bold">3.4 GB</div>
                </div>
                <div class="p-4 bg-black/20 border border-lab-border rounded-sm group hover:border-lab-cyan transition-colors">
                    <div class="text-lab-muted mb-1">Network I/O</div>
                    <div class="text-white text-lg font-bold">1.2 MB/s</div>
                </div>
                <div class="p-4 bg-black/20 border border-lab-border rounded-sm group hover:border-lab-terminal transition-colors">
                    <div class="text-lab-muted mb-1">Active Containers</div>
                    <div class="text-lab-primary text-lg font-bold">4/7</div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            <!-- CARD: Symfony Test Bench -->
            <article class="admin-card p-6 flex flex-col justify-between" style="border-left: 2px solid #00c6ff;">
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-lab-primary"><i data-lucide="flask-conical" class="w-5 h-5"></i></span>
                        <span class="text-[9px] font-mono text-lab-terminal tracking-widest">NOMINAL</span>
                    </div>
                    <h3 class="font-bold text-white text-sm uppercase tracking-tight mb-2">Symfony Test Bench</h3>
                    <p class="text-[11px] text-lab-muted font-mono leading-relaxed">Testing stateful components and new routing logic.</p>
                </div>
                <div class="mt-6 pt-4 border-t border-lab-border/50 text-[10px] font-mono uppercase">
                    <div class="text-lab-muted">Uptime: 45 days</div>
                    <div class="text-lab-primary">Coverage: 85%</div>
                </div>
            </article>

            <!-- CARD: Security Playground -->
            <article class="admin-card p-6 flex flex-col justify-between" style="border-left: 2px solid #ff3366;">
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-lab-danger"><i data-lucide="shield-alert" class="w-5 h-5"></i></span>
                        <span class="text-[9px] font-mono text-lab-danger animate-pulse tracking-widest">WARNING</span>
                    </div>
                    <h3 class="font-bold text-white text-sm uppercase tracking-tight mb-2">Security Playground</h3>
                    <p class="text-[11px] text-lab-muted font-mono leading-relaxed">Active fuzzing running against the JWT module endpoint.</p>
                </div>
                <div class="mt-6 pt-4 border-t border-lab-border/50 text-[10px] font-mono uppercase">
                    <div class="text-lab-muted">Target: /api/auth</div>
                    <div class="text-lab-danger">Last: CSRF (FIXED)</div>
                </div>
            </article>

            <!-- CARD: Docker/Devcontainer Lab -->
            <article class="admin-card p-6 flex flex-col justify-between" style="border-left: 2px solid #4df4ff;">
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-lab-cyan"><i data-lucide="container" class="w-5 h-5"></i></span>
                        <span class="text-[9px] font-mono text-lab-terminal tracking-widest">NOMINAL</span>
                    </div>
                    <h3 class="font-bold text-white text-sm uppercase tracking-tight mb-2">Docker / LXC Lab</h3>
                    <p class="text-[11px] text-lab-muted font-mono leading-relaxed">Image optimization and multi-architecture build definitions.</p>
                </div>
                <div class="mt-6 pt-4 border-t border-lab-border/50 text-[10px] font-mono uppercase">
                    <div class="text-lab-muted">Images: 12</div>
                    <div class="text-lab-cyan">Build: 3h ago</div>
                </div>
            </article>

            <!-- CARD: Automation & Scripts -->
            <article class="admin-card p-6 flex flex-col justify-between" style="border-left: 2px solid #00ff88;">
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-lab-terminal"><i data-lucide="zap" class="w-5 h-5"></i></span>
                        <span class="text-[9px] font-mono text-lab-terminal tracking-widest">RUNNING</span>
                    </div>
                    <h3 class="font-bold text-white text-sm uppercase tracking-tight mb-2">Automation & Scripts</h3>
                    <p class="text-[11px] text-lab-muted font-mono leading-relaxed">Monitoring crons and CI/CD webhook listeners.</p>
                </div>
                <div class="mt-6 pt-4 border-t border-lab-border/50 text-[10px] font-mono uppercase">
                    <div class="text-lab-muted">Jobs Queued: 0</div>
                    <div class="text-lab-terminal">Last: Success</div>
                </div>
            </article>

            <!-- CARD: Technical Notes -->
            <article class="admin-card p-6 flex flex-col justify-between" style="border-left: 2px solid #a855f7;">
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-purple-400"><i data-lucide="file-code" class="w-5 h-5"></i></span>
                        <span class="text-[9px] font-mono text-lab-terminal tracking-widest">NOMINAL</span>
                    </div>
                    <h3 class="font-bold text-white text-sm uppercase tracking-tight mb-2">Technical Notes</h3>
                    <p class="text-[11px] text-lab-muted font-mono leading-relaxed">Scratchpad and persistent command history.</p>
                </div>
                <div class="mt-6 pt-4 border-t border-lab-border/50 text-[10px] font-mono uppercase">
                    <div class="text-lab-muted">Pages: 42</div>
                    <div class="text-purple-400">Edit: 15m ago</div>
                </div>
            </article>

            <!-- CARD: Architecture Sandbox -->
            <article class="admin-card p-6 flex flex-col justify-between" style="border-left: 2px solid #fde047;">
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-yellow-400"><i data-lucide="boxes" class="w-5 h-5"></i></span>
                        <span class="text-[9px] font-mono text-lab-muted tracking-widest">IDLE</span>
                    </div>
                    <h3 class="font-bold text-white text-sm uppercase tracking-tight mb-2">Architecture Sandbox</h3>
                    <p class="text-[11px] text-lab-muted font-mono leading-relaxed">Conceptual diagrams and communication PoC.</p>
                </div>
                <div class="mt-6 pt-4 border-t border-lab-border/50 text-[10px] font-mono uppercase">
                    <div class="text-lab-muted">Activity: Low</div>
                    <div class="text-yellow-400">Project: Queue</div>
                </div>
            </article>

            <!-- CARD: OSINT / Exploration -->
            <article class="admin-card p-6 flex flex-col justify-between" style="border-left: 2px solid #34d399;">
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-emerald-400"><i data-lucide="globe" class="w-5 h-5"></i></span>
                        <span class="text-[9px] font-mono text-lab-terminal tracking-widest">NOMINAL</span>
                    </div>
                    <h3 class="font-bold text-white text-sm uppercase tracking-tight mb-2">OSINT / Exploration</h3>
                    <p class="text-[11px] text-lab-muted font-mono leading-relaxed">External data processing and reconnaissance scripts.</p>
                </div>
                <div class="mt-6 pt-4 border-t border-lab-border/50 text-[10px] font-mono uppercase">
                    <div class="text-lab-muted">Jobs: 5</div>
                    <div class="text-emerald-400">Scan: OK</div>
                </div>
            </article>
        </div>
    </div>
{% endblock %}
