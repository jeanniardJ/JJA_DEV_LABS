<div id="conversion-cta" 
     data-controller="conversion-tunnel"
     data-conversion-tunnel-target-url-value="{{ target_url }}"
     data-conversion-tunnel-severity-value="{{ severity }}"
     data-conversion-tunnel-count-value="{{ vulnerability_count }}"
     class="mt-6 p-6 bg-gradient-to-br from-lab-bg to-black border border-lab-primary/30 rounded-md shadow-lg animate-fade-in">
    
    <div class="flex items-center gap-4 mb-4">
        <div class="p-3 bg-lab-primary/10 rounded-full">
            <i data-lucide="calendar-check" class="w-6 h-6 text-lab-primary"></i>
        </div>
        <div class="text-left">
            <h4 class="text-sm font-bold text-white font-mono uppercase tracking-tight">
                {{ hook_message }}
            </h4>
            <p class="text-[10px] text-lab-muted font-mono">
                Discutons de ces {{ vulnerability_count }} vulnérabilité(s) identifiée(s) sur {{ target_url }}
            </p>
        </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-3">
        <a href="{{ path('app_website_appointments', {
                context: 'scan',
                site: target_url,
                severity: severity,
                count: vulnerability_count
           }) }}" 
           class="flex-1 bg-lab-primary hover:bg-lab-cyan text-black font-bold py-3 px-6 rounded-sm text-xs font-mono transition-all text-center flex items-center justify-center gap-2 group">
            DISCUTER_AVEC_UN_EXPERT
            <i data-lucide="arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1"></i>
        </a>
    </div>
</div>
