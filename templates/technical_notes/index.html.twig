{% extends 'base.html.twig' %}

{% block title %}JJA DEV LAB | Technical Notes{% endblock %}

{% block stylesheets %}
<style>
    /* Terminal Editor Style */
    .editor-box {
        background: #000;
        border: 1px solid #00c6ff;
        box-shadow: 0 0 10px rgba(0, 198, 255, 0.2);
    }
    .line-number {
        color: #1a2332;
        padding-right: 1rem;
        text-align: right;
        user-select: none;
        font-size: 0.75rem;
        line-height: 1.5rem;
        border-right: 1px solid #1a2332;
    }
</style>
{% endblock %}

{% block body %}
    <!-- HEADER DE LA PAGE -->
    <section class="mb-12 border-b border-lab-primary/50 pb-4">
        <h1 class="text-3xl md:text-4xl font-bold text-white flex items-center gap-4">
            <i data-lucide="file-text" class="w-8 h-8 text-lab-cyan"></i>
            <span class="text-lab-cyan">TECHNICAL NOTES & SCRATCHPAD</span>
        </h1>
        <p class="text-lab-muted font-mono mt-2 text-sm">
            /root/lab-data/notes/current_session.log: Persistent command history and architecture thoughts.
        </p>
    </section>

    <!-- EDITOR AREA -->
    <section class="mb-12">
        <div class="editor-box rounded-md overflow-hidden flex flex-col h-[70vh]">
            <!-- Editor Header -->
            <div class="bg-lab-panel/70 border-b border-lab-border flex justify-between items-center px-4 py-2 font-mono text-xs text-lab-muted">
                <span>File: /tmp/session_scratchpad.md</span>
                <div class="flex gap-4">
                    <button class="hover:text-lab-primary flex items-center gap-1"><i data-lucide="save" class="w-3 h-3"></i> Save</button>
                    <button class="hover:text-lab-terminal flex items-center gap-1"><i data-lucide="upload" class="w-3 h-3"></i> Sync</button>
                </div>
            </div>

            <!-- Editor Body: Line Numbers + Text Area -->
            <div class="flex flex-1 overflow-hidden">
                <!-- Line Numbers (fixed width) -->
                <div class="bg-black/90 line-number py-4 flex-shrink-0 w-12" id="line-numbers">
                    <!-- Numbers are generated by JS for a dynamic feel -->
                </div>

                <!-- Text Area -->
                <textarea id="note-editor" class="flex-1 p-4 bg-black/90 font-mono text-sm text-lab-terminal resize-none outline-none placeholder:text-lab-muted/50 focus:ring-0 border-0" placeholder="// Add your technical notes here..."></textarea>
            </div>

            <!-- Editor Footer -->
            <div class="bg-lab-panel/70 border-t border-lab-border flex justify-between items-center px-4 py-2 font-mono text-[10px] text-lab-muted">
                <span>Line: 1 | Col: 1</span>
                <span>Mode: Markdown | Status: EDITTING <span class="animate-blink bg-lab-primary w-1 h-2 inline-block align-middle"></span></span>
            </div>
        </div>
    </section>
    
    <!-- COMMONLY USED SNIPPETS -->
    <section id="snippets">
        <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
            <i data-lucide="code" class="w-5 h-5 text-lab-terminal"></i> Recent Snippets
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            
            <div class="glass-panel p-4 rounded-sm border border-lab-border">
                <span class="text-lab-terminal font-mono text-xs block mb-2">// Symfony Cache Clear Force</span>
                <pre class="font-mono text-xs bg-black/50 p-2 rounded-sm text-lab-primary overflow-x-auto">php bin/console cache:clear --env=prod --no-warmup</pre>
            </div>

            <div class="glass-panel p-4 rounded-sm border border-lab-border">
                <span class="text-lab-terminal font-mono text-xs block mb-2">// Docker Compose Cleanup</span>
                <pre class="font-mono text-xs bg-black/50 p-2 rounded-sm text-lab-primary overflow-x-auto">docker compose down --volumes --rmi all</pre>
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts_footer %}
    <script>
        // Script to dynamically generate line numbers and keep them in sync
        const editor = document.getElementById('note-editor');
        const lineNumbers = document.getElementById('line-numbers');

        function updateLineNumbers() {
            const lineCount = editor.value.split('\n').length;
            let numbers = '';
            for (let i = 1; i <= lineCount; i++) {
                // Generates a dynamic line number block with a slight cyan glow on the current line
                const isCurrentLine = i === 1; // Simplification: we could add logic for caret position
                numbers += `<div class="p-0.5 pr-2" style="color: ${isCurrentLine ? '#00c6ff' : '#1a2332'};">${i}</div>`;
            }
            lineNumbers.innerHTML = numbers;
        }

        // Initial generation and update on input/scroll
        updateLineNumbers();
        editor.addEventListener('input', updateLineNumbers);
        editor.addEventListener('scroll', () => {
             // Sync scroll position
             lineNumbers.scrollTop = editor.scrollTop;
        });
        
        // Add initial mock content for better visual
        editor.value =
`# SYMFONY: Architecture & Security
// Note: Consider using custom voters for more granular security on entities.

[AUTH_CONFIG]
security:
    firewalls:
        main:
            lazy: true
            provider: app_user_provider
            jwt: ~  # Utilizing LexikJWTAuthenticationBundle
    access_control:
        - { path: ^/api/docs, roles: PUBLIC_ACCESS }
        - { path: ^/api, roles: IS_AUTHENTICATED_FULLY }

# DOCKER: Multi-stage build
FROM node:20 as builder
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build:prod

FROM php:8.3-fpm-alpine
COPY --from=builder /app/public/build /var/www/html/public/build
// ... rest of PHP setup
`;
        updateLineNumbers(); // Update numbers for the mock content
    </script>
{% endblock %}
```