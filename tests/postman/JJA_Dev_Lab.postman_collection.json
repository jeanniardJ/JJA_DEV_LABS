{
	"info": {
		"_postman_id": "jja-dev-lab-scan",
		"name": "JJA Dev Lab - Scanner API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Submit Scan",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.scan_id) {",
							"    pm.collectionVariables.set("scan_id", jsonData.scan_id);",
							"    pm.collectionVariables.set("scan_token", jsonData.token);",
							"    console.log("Scan ID:", jsonData.scan_id);",
							"}",
							"pm.test("Status code is 200", function () {",
							"    pm.response.to.have.status(200);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "X-CSRF-Token",
						"value": "{{csrf_token}}",
						"description": "Extract from page manually or via script"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{
    "url": "{{target_url}}"
}"
				},
				"url": {
					"raw": "{{base_url}}/api/scanner/submit",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"scanner",
						"submit"
					]
				}
			},
			"response": []
		},
		{
			"name": "2. Verify Ownership",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "X-CSRF-Token",
						"value": "{{csrf_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{
    "method": "file"
}"
				},
				"url": {
					"raw": "{{base_url}}/api/scanner/verify/{{scan_id}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"scanner",
						"verify",
						"{{scan_id}}"
					]
				},
				"description": "Note: This will likely fail on localhost due to SSRF protection unless targeting a public IP."
			},
			"response": []
		},
		{
			"name": "3. Check Status",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/scanner/status/{{scan_id}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"scanner",
						"status",
						"{{scan_id}}"
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000"
		},
		{
			"key": "target_url",
			"value": "https://example.com"
		},
		{
			"key": "csrf_token",
			"value": "REPLACE_WITH_REAL_TOKEN"
		},
		{
			"key": "scan_id",
			"value": ""
		},
		{
			"key": "scan_token",
			"value": ""
		}
	]
}
